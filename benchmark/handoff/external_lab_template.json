{
  "trial_id": "external-lab-supported-columns-handoff",
  "description": "Template for an external lab no-manual-CSV-edit handoff trial. Replace placeholders with the lab handoff directory and expected object CSVs.",
  "morphojet_objects_csv": "{base_dir}/morphojet/Objects.csv",
  "exports": [
    {
      "name": "Cells",
      "object_set": "Cells",
      "channels": ["DNA", "PH3"],
      "out_csv": "{base_dir}/morphojet/Cells.wide.csv",
      "expected_cellprofiler_csv": "{base_dir}/cellprofiler/Cells.csv",
      "comparison_report": "{base_dir}/workflow_bridge.md",
      "comparison_json": "{base_dir}/workflow_bridge.json"
    }
  ],
  "downstream_checks": [
    {
      "name": "Validate Cells wide CSV downstream contract",
      "command": [
        "python3",
        "benchmark/check_cellprofiler_wide_contract.py",
        "{base_dir}/morphojet/Cells.wide.csv",
        "--channels",
        "DNA,PH3",
        "--min-rows",
        "1",
        "--json-out",
        "{base_dir}/handoff_contract.json"
      ],
      "artifacts": ["{base_dir}/handoff_contract.json"]
    }
  ]
}
