{
  "trial_id": "external-lab-supported-columns-handoff",
  "description": "Template for an external lab no-manual-CSV-edit handoff trial. Replace placeholders with the lab handoff directory and expected object CSVs.",
  "external_evidence": {
    "lab_or_org": "REPLACE_WITH_EXTERNAL_LAB_OR_ORG",
    "workflow_owner": "REPLACE_WITH_OWNER_NAME_OR_ROLE",
    "dataset_name": "REPLACE_WITH_DATASET_OR_BATCH_NAME",
    "dataset_source": "REPLACE_WITH_SOURCE_SYSTEM_OR_EXPORT_PATH",
    "downstream_workflow": "REPLACE_WITH_DOWNSTREAM_WORKFLOW_NAME",
    "execution_environment": "REPLACE_WITH_OS_HOST_AND_TOOL_VERSIONS",
    "reviewer_name_or_role": "REPLACE_WITH_REVIEWER_NAME_OR_ROLE",
    "reviewed_at_utc": "REPLACE_WITH_REVIEW_TIMESTAMP_UTC",
    "signoff_statement": "REPLACE_WITH_EXTERNAL_REVIEW_SIGNOFF_STATEMENT",
    "manual_csv_editing": false,
    "acceptance_criteria": [
      "MorphoJet-generated wide CSV is consumed by the existing downstream workflow without manual CSV edits.",
      "Supported CellProfiler-style columns pass comparison against the expected CellProfiler object CSV.",
      "Downstream contract checks pass with the real batch row count and required columns."
    ]
  },
  "morphojet_objects_csv": "{base_dir}/morphojet/Objects.csv",
  "required_object_metadata_columns": ["Plate", "Well", "Site"],
  "exports": [
    {
      "name": "Cells",
      "object_set": "Cells",
      "channels": ["DNA", "PH3"],
      "out_csv": "{base_dir}/morphojet/Cells.wide.csv",
      "expected_cellprofiler_csv": "{base_dir}/cellprofiler/Cells.csv",
      "comparison_report": "{base_dir}/workflow_bridge.md",
      "comparison_json": "{base_dir}/workflow_bridge.json"
    }
  ],
  "downstream_checks": [
    {
      "name": "Validate Cells wide CSV downstream contract",
      "command": [
        "python3",
        "benchmark/check_cellprofiler_wide_contract.py",
        "{base_dir}/morphojet/Cells.wide.csv",
        "--channels",
        "DNA,PH3",
        "--metadata-columns",
        "Plate,Well,Site",
        "--min-rows",
        "1",
        "--json-out",
        "{base_dir}/handoff_contract.json"
      ],
      "artifacts": ["{base_dir}/handoff_contract.json"]
    }
  ]
}
